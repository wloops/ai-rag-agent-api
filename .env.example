# Local development example.
# DATABASE_URL is for local host access.
# docker compose in this directory will override DATABASE_URL to use db:5432.

POSTGRES_USER=ai_rag_agent
POSTGRES_PASSWORD=change_me_123
POSTGRES_DB=ai_rag_agent

DATABASE_URL=postgresql://ai_rag_agent:change_me_123@localhost:5432/ai_rag_agent

SECRET_KEY=replace_with_a_random_secret_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

EMBEDDING_API_KEY=replace_with_embedding_api_key
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

LLM_API_KEY=replace_with_llm_api_key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=glm-4.5-air
