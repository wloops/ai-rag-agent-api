# Local development example.
# DATABASE_URL is for local host access.
# docker compose in this directory will override DATABASE_URL to use db:5432.

POSTGRES_USER=ai_rag_agent
POSTGRES_PASSWORD=change_me_123
POSTGRES_DB=ai_rag_agent

DATABASE_URL=postgresql://ai_rag_agent:change_me_123@localhost:5432/ai_rag_agent

SECRET_KEY=replace_with_a_random_secret_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
CELERY_TASK_ALWAYS_EAGER=false
CELERY_TASK_EAGER_PROPAGATES=true
CELERY_DOCUMENT_MAX_RETRIES=3
CELERY_DOCUMENT_RETRY_BASE_SECONDS=5

EMBEDDING_API_KEY=replace_with_embedding_api_key
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

LLM_API_KEY=replace_with_llm_api_key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=glm-4.5-air

RERANK_ENABLED=false
RERANK_API_KEY=
RERANK_BASE_URL=
RERANK_MODEL=
RERANK_TOP_N=5

RETRIEVAL_DENSE_CANDIDATE_K=12
RETRIEVAL_BM25_CANDIDATE_K=12
RETRIEVAL_FUSION_CANDIDATE_K=16
RETRIEVAL_FINAL_TOP_K=5
RETRIEVAL_RELEVANCE_THRESHOLD=0.35

# Comma-separated origins for browser clients.
CORS_ALLOW_ORIGINS=http://localhost:3000,https://rag.restflux.online
